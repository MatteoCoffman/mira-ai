# OpenAI
OPENAI_API_KEY=

# LangSmith (optional but recommended)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=mira-ai

# Database — DynamoDB (default, requires CDK deploy + AWS creds)
MIRA_DB_BACKEND=dynamodb
AWS_REGION=us-east-1
MIRA_TABLE_PREFIX=mira

# SQLite fallback (pytest sets this automatically; use for offline dev)
# MIRA_DB_BACKEND=sqlite
# MIRA_DB_PATH=.mira/mira.db

# Twilio — phone demo + owner SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Owner SMS for demos — overrides seeded fake numbers like +15551234567
# Use your real cell in E.164 format, e.g. +15125551234
MIRA_OWNER_SMS_PHONE=

# Public URL for Twilio HTTP webhooks (ngrok locally, or ApiFunctionUrl from cdk deploy)
# Example: https://abc123.ngrok-free.app
# Example: https://xxxxxxxx.lambda-url.us-east-1.on.aws/
MIRA_PUBLIC_URL=

# ConversationRelay WebSocket (injected by CDK on deploy; required for live phone after IVR)
# Example: wss://xxxx.execute-api.us-east-1.amazonaws.com/prod
# CONVERSATION_RELAY_WSS_URL=

# Public HTTPS URL for the IVR menu MP3 (optional; defaults to {MIRA_PUBLIC_URL}/assets/ivr-menu.mp3)
# MIRA_IVR_AUDIO_URL=

# Optional — used by scripts/generate_ivr_audio.py for an exact ConversationRelay voice match
# ELEVENLABS_API_KEY=

# Set automatically on Lambda after CDK deploy — local dev uses .env instead
# MIRA_SECRETS_ARN=
