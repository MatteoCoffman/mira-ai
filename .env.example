# OpenAI
OPENAI_API_KEY=

# LangSmith (optional but recommended)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=mira-ai

# Database — DynamoDB (default, requires CDK deploy + AWS creds)
MIRA_DB_BACKEND=dynamodb
AWS_REGION=us-east-1
MIRA_TABLE_PREFIX=mira

# SQLite fallback (pytest sets this automatically; use for offline dev)
# MIRA_DB_BACKEND=sqlite
# MIRA_DB_PATH=.mira/mira.db

# Twilio — phone demo + owner SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Owner SMS for demos — overrides seeded fake numbers like +15551234567
# Use your real cell in E.164 format, e.g. +15125551234
MIRA_OWNER_SMS_PHONE=

# Public URL for Twilio webhooks (ngrok or deployed API)
# Example: https://abc123.ngrok-free.app
MIRA_PUBLIC_URL=
